# Excel Tech Radar - Environment Configuration
# Copy this file to .env and customize for your environment

# ===== Server Configuration =====
# Host to bind the server to (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
RADAR_HOST=127.0.0.1

# Port to run the server on
RADAR_PORT=8080

# Debug mode (true/false) - DO NOT enable in production
RADAR_DEBUG=false

# ===== Data Configuration =====
# Directory where Excel project files are stored
RADAR_DATA_DIR=./data

# Directory for built/exported files
RADAR_DIST_DIR=./dist

# ===== Backup Configuration =====
# Enable automatic backups when saving changes
RADAR_BACKUP_ENABLED=true

# Maximum number of backup files to keep per project
RADAR_MAX_BACKUPS=5

# Number of days to keep deleted files before permanent removal
RADAR_RETENTION_DAYS=30

# ===== Logging Configuration =====
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
RADAR_LOG_LEVEL=INFO

# Log file path (leave empty to disable file logging)
RADAR_LOG_FILE=./logs/radar.log

# Log format: text or json
RADAR_LOG_FORMAT=text

# ===== Security Configuration =====
# Secret key for session management (generate a random string for production)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RADAR_SECRET_KEY=change-me-in-production

# Allowed CORS origins (comma-separated, use * for all)
RADAR_ALLOWED_ORIGINS=*

# ===== Feature Flags =====
# Enable/disable specific features
RADAR_ENABLE_EXPORT=true
RADAR_ENABLE_IMPORT=true
RADAR_ENABLE_DELETE=true

# ===== Performance =====
# Maximum file upload size in MB
RADAR_MAX_UPLOAD_SIZE=10

# Request timeout in seconds
RADAR_REQUEST_TIMEOUT=30
